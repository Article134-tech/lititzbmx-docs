{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "chapter.schema.json",
  "type": "object",
  "required": [
    "record_id",
    "chapter_number",
    "title",
    "google_sites_url",
    "source_images",
    "status"
  ],
  "properties": {
    "record_id": {
      "type": "string",
      "pattern": "^HUFFY-CH-[0-9]{2}$"
    },
    "chapter_number": {
      "type": "integer",
      "minimum": 1,
      "maximum": 10
    },
    "title": {
      "type": "string"
    },
    "google_sites_url": {
      "type": "string",
      "format": "uri"
    },
    "source_images": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "string"
      }
    },
    "page_captures": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "status": {
      "const": "verified"
    }
  },
  "additionalProperties": true
}
