{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "record_type",
    "record_id",
    "page_number",
    "status",
    "source_url",
    "expected_entries",
    "transcribed_entries"
  ],
  "properties": {
    "record_type": {
      "const": "track_profile_source_page"
    },
    "record_id": {
      "type": "string"
    },
    "page_number": {
      "type": "integer",
      "minimum": 1,
      "maximum": 10
    },
    "status": {
      "enum": [
        "source_complete",
        "source_capture_pending"
      ]
    },
    "source_url": {
      "type": "string",
      "format": "uri"
    },
    "expected_entries": {
      "const": 15
    },
    "transcribed_entries": {
      "type": "integer",
      "minimum": 0,
      "maximum": 15
    }
  }
}
