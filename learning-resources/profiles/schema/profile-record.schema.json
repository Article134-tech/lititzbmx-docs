  "type": "object",
  "required": [
    "schema_version",
    "record_type",
    "record_id",
    "status",
    "source_url"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "record_type": {
      "type": "string"
    },
    "record_id": {
      "type": "string"
    },
    "status": {
      "type": "string"
    },
    "source_url": {
      "type": "string",
      "format": "uri"
    }
  }
}
